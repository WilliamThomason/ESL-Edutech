# Environment variables for the tutoring platform
# Copy this to .env and fill in your values

# ── Domain ────────────────────────────────────────────────
# Your domain name (e.g., tutoring.example.com)
DOMAIN=tutoring.example.com
# Your server's public IP (for TURN server)
SERVER_IP=auto

# ── Cal.com ──────────────────────────────────────────────
CALCOM_NEXTAUTH_SECRET=change-me-to-random-32-characters
CALCOM_ENCRYPTION_KEY=change-me-to-another-32-chars

# ── LiveKit ──────────────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── TURN Server ──────────────────────────────────────────
TURN_SECRET=turn-secret-change-me

# ── MinIO ────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ── Custom API ───────────────────────────────────────────
JWT_SECRET=jwt-secret-change-me

# ── Email (SMTP) ─────────────────────────────────────────
# For booking confirmations and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
